# Environment for the production compose stack (backend/docker-compose.yml).
# Copy to backend/.env on the host and edit. docker compose / finch compose
# auto-loads a `.env` sitting next to the compose file.

# Public base URL of the PocketBase backend, as reached from a browser/phone
# (i.e. the hostname your reverse proxy routes to posedeck-pb:8090). This is
# baked into the web bundle at BUILD time, so changing it requires:
#   docker compose build web   (or: finch compose build web)
POSEDECK_API_URL=https://api.shotdeck.yourdomain.com

# Host ports each service publishes (left side of the `ports:` mapping). Change
# these to avoid clashes with other services on the host; your reverse proxy
# maps your domain -> <host-ip>:<port>. The container-side ports are fixed.
# Defaults shown; uncomment to override.
#POSEDECK_PB_PORT=8090
#POSEDECK_WEB_PORT=8080
#POSEDECK_ANISETTE_PORT=6969
