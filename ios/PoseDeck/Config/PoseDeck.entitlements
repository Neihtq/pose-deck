<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Keychain access group for the persisted auth session (token + user).
	  Without an explicit group, an app must rely on the application-identifier
	  entitlement, which an unsigned simulator build (CODE_SIGNING_ALLOWED=NO)
	  lacks — Keychain SecItem calls then fail with errSecMissingEntitlement
	  (-34018). Declaring a group lets the app reach the Keychain when ad-hoc
	  signed for the simulator (UI tests) and is harmless on a provisioned
	  device.

	  Use Apple's standard variable form, NOT a hardcoded string:
	  `$(AppIdentifierPrefix)$(CFBundleIdentifier)` expands to the team-prefixed,
	  bundle-id-matching group that the automatic provisioning profile expects on
	  a real device. A hardcoded literal (e.g. `dev.posedeck.app`) breaks
	  automatic signing the moment the bundle id is customized (e.g. made unique
	  for a free Personal Team) — the profile's keychain group no longer matches
	  the entitlement. On the simulator AppIdentifierPrefix resolves to empty, so
	  the group is just the bundle id and ad-hoc Keychain access still works.
	-->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)$(CFBundleIdentifier)</string>
	</array>
</dict>
</plist>
